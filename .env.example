# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/huawei_autopublish"

# OpenAI (text metadata generation + gpt-image screenshots). Can also be set in Settings.
OPENAI_API_KEY=""

# Google Gemini (text + "nano banana" gemini-2.5-flash-image screenshots). Optional; can be set in Settings.
GEMINI_API_KEY=""

# DeepSeek (text metadata via OpenAI-compatible endpoint). Optional; can be set in Settings.
DEEPSEEK_API_KEY=""

# Huawei AppGallery Connect API — used by the Fastlane plugin for ALL publishing.
# Get these from: Console → Users and permissions → Connect API
HUAWEI_AGC_CLIENT_ID=""
HUAWEI_AGC_CLIENT_SECRET=""

# Privacy policy URL attached to the uploaded version (optional but recommended).
PRIVACY_POLICY_URL=""

# Fastlane runner overrides (defaults are usually fine):
#   FASTLANE_DIR        — path to the fastlane_runner/ directory
#   FASTLANE_USE_BUNDLER — "0" to call `fastlane` directly instead of `bundle exec`
#   APPGALLERYCLI_BIN   — path to the compiled appgallerycli binary
# FASTLANE_DIR=""
# APPGALLERYCLI_BIN=""

# VMOS Cloud (preferred for real-device screenshots — install APK on a
# user-provisioned pad and capture frames). Get AK/SK from
# https://cloud.vmoscloud.com/openapi
VMOSCLOUD_ACCESS_KEY_ID=""
VMOSCLOUD_SECRET_ACCESS_KEY=""
# padCode of the existing VMOS device that will host the APK during screenshot
# capture. Visible in your VMOS console → My devices.
VMOSCLOUD_PAD_CODE=""
# Public URL where this app is reachable so VMOS can pull the APK
# (defaults to NEXT_PUBLIC_APP_URL if unset).
APP_PUBLIC_URL=""

# Appetize.io (optional fallback for real Android emulator screenshots)
# Skip to fall back to template-based mockups
APPETIZE_API_TOKEN=""

# App config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"

# Worker
WORKER_POLL_INTERVAL_MS="5000"

# ---------------- Huawei Console (Playwright) automation ----------------
# Enables the browser-based fallback for fields the Connect API cannot set
# (content rating, personal data, AI declaration, release time; plus category
# and countries on brand-new apps).
HUAWEI_CONSOLE_AUTOMATION="1"

# Path to the persistent Chromium profile. Log in once with
#   npx tsx scripts/huawei-login.ts
# and the cookies survive between runs.
HUAWEI_PROFILE_DIR="/opt/huawei-profile"

# Optional: attach to an already-running Chrome via CDP instead of using the
# persistent profile. Useful for local debugging.
# HUAWEI_CDP_URL="http://localhost:9222"

# Optional: show a visible browser window (persistent profile mode). Leave 0
# for headless production.
# HUAWEI_HEADED="0"

# Category labels used by the console driver. Match your Huawei console UI
# text exactly. Defaults produce "Games / Role-playing / Incremental games"
# with the "Casual game" tag.
# HUAWEI_CATEGORY_PARENT_LABEL="Games"
# HUAWEI_CATEGORY_CHILD_LABEL="Role-playing"
# HUAWEI_CATEGORY_GRAND_LABEL="Incremental games"
# HUAWEI_CATEGORY_EXTRA_TAG="Casual game"
